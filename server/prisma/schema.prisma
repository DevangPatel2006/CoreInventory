// CoreInventory — Upgraded Schema
// Compatible with all existing route files
// Changes from original:
//   ✅ SQLite → PostgreSQL
//   ✅ Indexes on all FK + status + created_at columns
//   ✅ updatedAt on all mutable tables
//   ✅ scheduled_date on Operation (needed for dashboard "today's ops")
//   ✅ notes field on Operation
//   ✅ validated_at + validated_by on Operation
//   ✅ description on Product
//   ✅ short_code on Warehouse (needed for reference generation)
//   ✅ Decimal for quantity (no float rounding errors)

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  password_hash String
  role          String      @default("staff") // "manager" | "staff"
  is_active     Boolean     @default(true)
  reset_otp     String?
  otp_expiry    DateTime?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  operations          Operation[] @relation("CreatedBy")
  validated_operations Operation[] @relation("ValidatedBy")

  @@index([email])
  @@index([role])
}

model Category {
  id         String    @id @default(uuid())
  name       String    @unique
  created_at DateTime  @default(now())

  products   Product[]
}

model Product {
  id              String          @id @default(uuid())
  name            String
  sku             String          @unique
  description     String?
  category_id     String
  unit_of_measure String
  min_stock_level Decimal         @default(10) @db.Decimal(12, 3)
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  category        Category        @relation(fields: [category_id], references: [id])
  stock_locations StockLocation[]
  stock_moves     StockMove[]

  @@index([category_id])
  @@index([sku])
  @@index([is_active])
}

model Warehouse {
  id         String          @id @default(uuid())
  name       String
  short_code String          @unique
  address    String?
  is_active  Boolean         @default(true)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  locations  StockLocation[]

  @@index([is_active])
}

model StockLocation {
  id           String    @id @default(uuid())
  warehouse_id String
  product_id   String
  quantity     Decimal   @default(0) @db.Decimal(12, 3)
  updated_at   DateTime  @updatedAt

  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id])
  product      Product   @relation(fields: [product_id], references: [id])

  @@unique([warehouse_id, product_id])
  @@index([warehouse_id])
  @@index([product_id])
  @@index([quantity])     // needed for low-stock queries
}

model Operation {
  id             String      @id @default(uuid())
  type           String      // "receipt" | "delivery" | "transfer" | "adjust"
  status         String      @default("draft") // "draft" | "waiting" | "ready" | "done" | "cancelled"
  ref_number     String      @unique
  contact_name   String?     // supplier name for receipts, customer name for deliveries
  notes          String?
  scheduled_date DateTime?   // for dashboard filtering by date
  created_by     String
  validated_by   String?     // who clicked Validate
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  validated_at   DateTime?   // when status became "done"

  user           User        @relation("CreatedBy",   fields: [created_by],   references: [id])
  validator      User?       @relation("ValidatedBy", fields: [validated_by], references: [id])
  moves          StockMove[]

  @@index([type])
  @@index([status])
  @@index([created_by])
  @@index([created_at])
  @@index([type, status])   // composite — used by dashboard KPI queries
}

model StockMove {
  id            String    @id @default(uuid())
  operation_id  String
  product_id    String
  qty           Decimal   @db.Decimal(12, 3)
  from_location String?   // warehouse_id for transfers/deliveries/adjustments(negative)
  to_location   String?   // warehouse_id for transfers/receipts/adjustments(positive)
  created_at    DateTime  @default(now())

  operation     Operation @relation(fields: [operation_id], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [product_id],   references: [id])

  @@index([operation_id])
  @@index([product_id])
  @@index([created_at])
}

model ReorderRule {
  id           String   @id @default(uuid())
  product_id   String   @unique
  warehouse_id String
  min_qty      Decimal  @db.Decimal(12, 3)
  reorder_qty  Decimal  @db.Decimal(12, 3)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([product_id])
  @@index([warehouse_id])
}
