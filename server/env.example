# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# Local development (Railway PostgreSQL or Supabase)
DATABASE_URL="postgresql://user:password@host:5432/coreinventory"

# Railway: paste the DATABASE_URL from your Railway PostgreSQL service dashboard
# Supabase: paste the connection string from Project Settings → Database → Connection String

JWT_SECRET="replace-this-with-any-long-random-string-before-demo"
JWT_EXPIRES_IN="24h"

PORT=5000
NODE_ENV=development

# OTP Email (optional — only needed for forgot-password flow)
# Create a Gmail App Password at: myaccount.google.com/apppasswords
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
