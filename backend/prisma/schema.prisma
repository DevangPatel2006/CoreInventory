generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  password_hash String
  role          String      // "manager" or "staff"
  reset_otp     String?
  otp_expiry    DateTime?
  operations    Operation[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  products Product[]
}

model Product {
  id              String          @id @default(uuid())
  name            String
  sku             String          @unique
  category_id     String
  unit_of_measure String
  min_stock_level Int             @default(0)
  
  category        Category        @relation(fields: [category_id], references: [id])
  stock_locations StockLocation[]
  stock_moves     StockMove[]
}

model Warehouse {
  id        String          @id @default(uuid())
  name      String
  address   String?
  is_active Boolean         @default(true)
  locations StockLocation[]
}

model StockLocation {
  id           String    @id @default(uuid())
  warehouse_id String
  product_id   String
  quantity     Int       @default(0)

  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id])
  product      Product   @relation(fields: [product_id], references: [id])

  @@unique([warehouse_id, product_id]) // cant have 2 rows for same product in same warehouse
}

model Operation {
  id           String      @id @default(uuid())
  type         String      // "receipt", "delivery", "transfer", "adjust"
  status       String      @default("draft") // draft, waiting, ready, done
  ref_number   String
  contact_name String?
  created_by   String
  created_at   DateTime    @default(now())

  user         User        @relation(fields: [created_by], references: [id])
  moves        StockMove[]
}

model StockMove {
  id            String    @id @default(uuid())
  operation_id  String
  product_id    String
  qty           Int
  from_location String?   // Warehouse ID for transfers/deliveries
  to_location   String?   // Warehouse ID for transfers/receipts

  operation     Operation @relation(fields: [operation_id], references: [id])
  product       Product   @relation(fields: [product_id], references: [id])
}
